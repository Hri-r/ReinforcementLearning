<mujoco model="four_legged_bot">
  <default/>
    <worldbody>
        <geom name="ground" type="plane" size="100 100 0.1" rgba="0.2 0.2 0.2 1"/>

        <!-- <body name="torso" pos="0 0 0.4"> <inertial pos="0 0 0" mass="0.59" diaginertia="0.0013 0.0008 0.0016" /> -->
        <body name="torso" pos="0 0 0"> <inertial pos="0 0 0" mass="0.59" diaginertia="0.0013 0.0008 0.0016" />
          
          <geom name="torso_geom" type="box" size="0.075 0.05 0.0375" rgba="0.8 0.6 0.4 1"/>
          
          <joint name="torso_free_joint" type="free" damping="1"/>

          <body name="front_left_hip" pos="0.075 0.05 0" euler="0 0 0.7854">
            <inertial pos="0 0 0" mass="0.12" diaginertia="0.0001 0.0001 0.0001" />
            <joint name="front_left_hip_joint" type="hinge" axis="-1 1 0" range="-45 45" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
            <geom name="front_left_hip_geom" type="capsule" size="0.02" fromto="0 0 0 0.1 0.1 0" rgba="0.8 0.6 0.4 1"/>
            <body name="front_left_knee" pos="0.1 0.1 0">
              <joint name="front_left_knee_joint" type="hinge" axis="-1 1 0" range="0 80" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
              <geom name="front_left_knee_geom" type="capsule" size="0.02" fromto="0 0 0 0.1 0.1 0" rgba="0.8 0.6 0.4 1" friction="0.75 0.005 0.0001"/>
            </body>
          </body>

          <body name="front_right_hip" pos="0.075 -0.05 0" euler="0 0 -0.7854">
            <inertial pos="0 0 0" mass="0.12" diaginertia="0.0001 0.0001 0.0001" />
            <joint name="front_right_hip_joint" type="hinge" axis="-1 -1 0" range="-45 45" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
            <geom name="front_right_hip_geom" type="capsule" size="0.02" fromto="0 0 0 0.1 -0.1 0" rgba="0.8 0.6 0.4 1"/>
            <body name="front_right_knee" pos="0.1 -0.1 0">
              <joint name="front_right_knee_joint" type="hinge" axis="-1 -1 0" range="-80 0" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
              <geom name="front_right_knee_geom" type="capsule" size="0.02" fromto="0 0 0 0.1 -0.1 0" rgba="0.8 0.6 0.4 1" friction="0.75 0.005 0.0001"/>
            </body>
          </body>

          <body name="back_left_hip" pos="-0.075 0.05 0" euler="0 0 2.356">
            <inertial pos="0 0 0" mass="0.12" diaginertia="0.0001 0.0001 0.0001" />
            <joint name="back_left_hip_joint" type="hinge" axis="1 1 0" range="-45 45" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
            <geom name="back_left_hip_geom" type="capsule" size="0.02" fromto="0 0 0 -0.1 0.1 0" rgba="0.8 0.6 0.4 1"/>
            <body name="back_left_knee" pos="-0.1 0.1 0">
              <joint name="back_left_knee_joint" type="hinge" axis="1 1 0" range="-80 0" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
              <geom name="back_left_knee_geom" type="capsule" size="0.02" fromto="0 0 0 -0.1 0.1 0" rgba="0.8 0.6 0.4 1" friction="0.75 0.005 0.0001"/>
            </body>
          </body>

          <body name="back_right_hip" pos="-0.075 -0.05 0" euler="0 0 -2.356">
            <inertial pos="0 0 0" mass="0.12" diaginertia="0.0001 0.0001 0.0001" />
            <joint name="back_right_hip_joint" type="hinge" axis="1 -1 0" range="-45 45" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
            <geom name="back_right_hip_geom" type="capsule" size="0.02" fromto="0 0 0 -0.1 -0.1 0" rgba="0.8 0.6 0.4 1"/>
            <body name="back_right_knee" pos="-0.1 -0.1 0">
              <joint name="back_right_knee_joint" type="hinge" axis="1 -1 0" range="0 80" damping="0.5" solreflimit="0.01 1" solimplimit="0.95 0.99 0.001"/>
              <geom name="back_right_knee_geom" type="capsule" size="0.02" fromto="0 0 0 -0.1 -0.1 0" rgba="0.8 0.6 0.4 1" friction="0.75 0.005 0.0001"/>
            </body>
          </body>

        </body>
    </worldbody>

  <actuator>
    <motor joint="front_left_hip_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="front_left_knee_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="front_right_hip_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="front_right_knee_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="back_left_hip_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="back_left_knee_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="back_right_hip_joint" ctrlrange="-1 1" gear="1"/>
    <motor joint="back_right_knee_joint" ctrlrange="-1 1" gear="1"/>
  </actuator>
</mujoco>